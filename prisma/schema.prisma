// Cadence — Phase 1 (Model A) Prisma schema.
// Focused on the consumer-BNPL-via-Stripe flow plus the append-only ledger.
// Models B and C entities (see docs/04-data-model.md) are added in later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MoneyModel {
  CONSUMER // A — the only model wired in Phase 1
  B2B_TERMS // B — Phase 2
  MAKE_SELL // C — Phase 3
}

enum PartnerKind {
  BNPL_STRIPE // Klarna / Affirm via Stripe (A)
  RESOLVE // B — Phase 2
  EMBEDDED_CAPITAL // C — Phase 3
}

enum LinkStatus {
  DRAFT
  OPEN
  FUNDED
  EXPIRED
  CANCELLED
}

enum LedgerKind {
  FUNDING // partner funds the merchant in full (Model A)
  FEE // Cadence's share of the partner fee
  ADJUSTMENT // corrections (append-only; never edit prior rows)
}

model Merchant {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  stripeAccountId String?       @unique // Stripe Connect account
  createdAt       DateTime      @default(now())
  paymentLinks    PaymentLink[]
}

model Partner {
  id           String        @id @default(cuid())
  kind         PartnerKind
  displayName  String
  transactions Transaction[]
}

model PaymentLink {
  id          String       @id @default(cuid())
  merchantId  String
  merchant    Merchant     @relation(fields: [merchantId], references: [id])
  model       MoneyModel   @default(CONSUMER)
  amountCents BigInt
  currency    String       @default("usd")
  description String?
  status      LinkStatus   @default(OPEN)
  token       String       @unique // public, unguessable URL token
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
  transaction Transaction?

  @@index([merchantId, status])
}

model Transaction {
  id            String        @id @default(cuid())
  paymentLinkId String        @unique
  paymentLink   PaymentLink   @relation(fields: [paymentLinkId], references: [id])
  partnerId     String
  partner       Partner       @relation(fields: [partnerId], references: [id])
  amountCents   BigInt // funded to merchant in full
  feeCents      BigInt        @default(0) // Cadence's share of partner fee
  fundedAt      DateTime?
  ledgerEvents  LedgerEvent[]
}

// The system of record: append-only. Balances are derived from these rows.
model LedgerEvent {
  id            String       @id @default(cuid())
  kind          LedgerKind
  amountCents   BigInt
  currency      String       @default("usd")
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  sourceEventId String?      @unique // idempotency: ties to the external event that caused it
  createdAt     DateTime     @default(now())

  @@index([transactionId, kind])
}

// Raw, verified inbound webhooks. Unique on (source, externalId) → idempotent intake.
model WebhookEvent {
  id          String    @id @default(cuid())
  source      String // "stripe" | "resolve" | "embedded_capital"
  externalId  String
  payload     Json
  verifiedAt  DateTime?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([source, externalId])
}
