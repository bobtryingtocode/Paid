# Noctua Pay — environment variables (Phase 1, Model A)
# Copy to .env.local and fill in. NEVER commit real secrets.
# Only NEXT_PUBLIC_* vars are exposed to the client; partner keys must NOT use that prefix.

# Database — Supabase (Postgres). Get both from Supabase → Project Settings →
# Database → Connection string. DATABASE_URL is the POOLED connection (Supavisor,
# port 6543) used by the app; DIRECT_URL is the DIRECT connection (port 5432)
# used for migrations. Replace [ref], [password], [region].
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Auth.js (NextAuth) — session signing secret. Generate: openssl rand -base64 32
AUTH_SECRET="replace-me"

# Stripe — the rails (server-only)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public base URL for building payer links / Stripe redirect URLs.
# In production this is your Vercel URL, e.g. https://noctua-pay.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Outbound automation (Zapier) — non-PII workflow events are POSTed here.
# Use a Zapier "Catch Hook" trigger URL. Leave unset to run in stub mode (logs).
ZAPIER_WEBHOOK_URL=""
# Shared secret used to HMAC-sign the outbound payload (x-noctua-signature).
WEBHOOK_SIGNING_SECRET=""

# Email delivery for bills (optional). If unset, email runs in stub mode (logs).
# Resend: https://resend.com — EMAIL_FROM must be a verified sender/domain.
RESEND_API_KEY=""
EMAIL_FROM="bills@yourdomain.com"

# Anthropic (Claude) — the procure-to-pay invoice agent (server-only)
# ONE platform key for all customers; usage is metered per subscription tier.
ANTHROPIC_API_KEY="sk-ant-..."

# Billing — Stripe subscription Price IDs (created once in the Stripe dashboard)
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_SCALE="price_..."
# Separate webhook endpoint secret for subscription lifecycle events
STRIPE_BILLING_WEBHOOK_SECRET="whsec_..."
