# Cadence — environment variables (Phase 1, Model A)
# Copy to .env.local and fill in. NEVER commit real secrets.
# Only NEXT_PUBLIC_* vars are exposed to the client; partner keys must NOT use that prefix.

# Database (Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/cadence?schema=public"

# Auth.js (NextAuth) — session signing secret. Generate: openssl rand -base64 32
AUTH_SECRET="replace-me"

# Stripe — the rails (server-only)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public base URL for building payer links / Stripe redirect URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Anthropic (Claude) — the procure-to-pay invoice agent (server-only)
# ONE platform key for all customers; usage is metered per subscription tier.
ANTHROPIC_API_KEY="sk-ant-..."

# Billing — Stripe subscription Price IDs (created once in the Stripe dashboard)
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_SCALE="price_..."
# Separate webhook endpoint secret for subscription lifecycle events
STRIPE_BILLING_WEBHOOK_SECRET="whsec_..."
